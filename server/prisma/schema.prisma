generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model users {
  id            Int            @id @default(autoincrement())
  full_name     String
  email         String         @unique
  password_hash String
  role          String
  created_at    DateTime       @default(now())
  UserProgress  UserProgress[]
  courses       courses[]
  enrollments   enrollments[]
  exam_results  exam_results[]
}

model courses {
  id            Int           @id @default(autoincrement())
  instructor_id Int
  title         String        @unique
  description   String
  thumbnail_url String
  created_at    DateTime      @default(now())
  instructor    users         @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
  enrollments   enrollments[]
  exams         exams[]
  lessons       lessons[]
}

model lessons {
  id          Int      @id @default(autoincrement())
  course_id   Int
  title       String
  order_index Int
  course      courses  @relation(fields: [course_id], references: [id], onDelete: Cascade)
  topics      topics[]
}

model topics {
  id           Int            @id @default(autoincrement())
  lesson_id    Int
  title        String
  content_type String
  content_body String
  order_index  Int
  UserProgress UserProgress[]
  lesson       lessons        @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
}

model enrollments {
  id          Int      @id @default(autoincrement())
  student_id  Int
  course_id   Int
  enrolled_at DateTime @default(now())
  course      courses  @relation(fields: [course_id], references: [id], onDelete: Cascade)
  student     users    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, course_id])
}

model exams {
  id              Int            @id @default(autoincrement())
  course_id       Int
  title           String
  total_questions Int
  exam_results    exam_results[]
  course          courses        @relation(fields: [course_id], references: [id], onDelete: Cascade)
  questions       questions[]
}

model questions {
  id             Int    @id @default(autoincrement())
  exam_id        Int
  question_text  String
  option_a       String
  option_b       String
  option_c       String
  option_d       String
  correct_option String
  exam           exams  @relation(fields: [exam_id], references: [id], onDelete: Cascade)
}

model exam_results {
  id         Int      @id @default(autoincrement())
  student_id Int
  exam_id    Int
  score      Float
  taken_at   DateTime @default(now())
  exam       exams    @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  student    users    @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model UserProgress {
  id           Int      @id @default(autoincrement())
  user_id      Int
  topic_id     Int
  completed_at DateTime @default(now())
  topic        topics   @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  user         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, topic_id])
}
